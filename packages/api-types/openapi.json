          },
          "404": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              }
            }
          },
          "422": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              }
            }
          }
        }
      }
    },
    "/tareas/categoria/{categoria}": {
      "get": {
        "operationId": "listTareasByCategoria",
        "summary": "List tasks by status category",
        "tags": [
          "Tareas"
        ],
        "description": "Returns tasks whose related status category matches the path parameter. Uses a parameterized query (no SQL injection risk).",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "minLength": 1,
              "maxLength": 100
            },
            "in": "path",
            "name": "categoria",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Tarea"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/tareas/{id}": {
      "get": {
        "operationId": "getTarea",
        "summary": "Get a task by id",
        "tags": [
          "Tareas"
        ],
        "description": "Returns a single task with related employee and status names. 404 if not found.",
        "parameters": [
          {
            "schema": {
              "type": "integer",
              "minimum": 1
            },
            "in": "path",
            "name": "id",
            "required": true
          }
        ],
        "responses": {

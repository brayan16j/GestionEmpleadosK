{
  "openapi": "3.1.0",
  "info": {
    "title": "EmployeeK API",
    "version": "0.0.0",
    "description": "REST API for EmployeeK — employee and task management. Fastify 5 + Prisma + AJV + RFC 7807 error envelopes."
  },
  "components": {
    "schemas": {
      "HealthResponse": {
        "type": "object",
        "required": [
          "status"
        ],
        "properties": {
          "status": {
            "type": "string"
          }
        }
      },
      "Problem": {
        "type": "object",
        "required": [
          "type",
          "title",
          "status",
          "instance",
          "traceId"
        ],
        "properties": {
          "type": {
            "type": "string",
            "format": "uri"
          },
          "title": {
            "type": "string"
          },
          "status": {
            "type": "integer",
            "minimum": 100,
            "maximum": 599
          },
          "detail": {
            "type": "string"
          },
          "instance": {
            "type": "string"
          },
          "traceId": {
            "type": "string"
          },
          "errors": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "path",
                "message"
              ],
              "properties": {
                "path": {
                  "type": "string"
                },
                "message": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "Empleado": {
        "type": "object",
        "required": [
          "id",
          "nombre",
          "fechaIngreso",
          "salario",
          "createdAt",
          "updatedAt"
        ],
        "properties": {
          "id": {
            "type": "integer"
          },
          "nombre": {
            "type": "string"
          },
          "fechaIngreso": {
            "type": "string",
            "format": "date"
          },
          "salario": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "CreateEmpleadoBody": {
        "type": "object",
        "required": [
          "nombre",
          "fechaIngreso",
          "salario"
        ],
        "additionalProperties": false,
        "properties": {
          "nombre": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200
          },
          "fechaIngreso": {
            "type": "string",
            "format": "date"
          },
          "salario": {
            "type": "number",
            "minimum": 0
          }
        }
      },
      "UpdateEmpleadoBody": {
        "type": "object",
        "required": [
          "nombre",
          "fechaIngreso",
          "salario"
        ],
        "additionalProperties": false,
        "properties": {
          "nombre": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200
          },
          "fechaIngreso": {
            "type": "string",
            "format": "date"
          },
          "salario": {
            "type": "number",
            "minimum": 0
          }
        }
      },
      "EmpleadoIdParams": {
        "type": "object",
        "required": [
          "id"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "minimum": 1
          }
        }
      },
      "Estado": {
        "type": "object",
        "required": [
          "id",
          "nombre",
          "categoria"
        ],
        "properties": {
          "id": {
            "type": "integer"
          },
          "nombre": {
            "type": "string"
          },
          "categoria": {
            "type": "string"
          },
          "cambiosPermitidos": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "CreateEstadoBody": {
        "type": "object",
        "required": [
          "nombre",
          "categoria"
        ],
        "additionalProperties": false,
        "properties": {
          "nombre": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100
          },
          "categoria": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100
          },
          "cambiosPermitidos": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      },
      "UpdateEstadoBody": {
        "type": "object",
        "required": [
          "nombre",
          "categoria"
        ],
        "additionalProperties": false,
        "properties": {
          "nombre": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100
          },
          "categoria": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100
          },
          "cambiosPermitidos": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      },
      "EstadoIdParams": {
        "type": "object",
        "required": [
          "id"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "minimum": 1
          }
        }
      },
      "Tarea": {
        "type": "object",
        "required": [
          "id",
          "nombre",
          "fechaCreacion",
          "fechaInicioTarea",
          "fechaFinalizacion",
          "idEmpleado",
          "idEstado"
        ],
        "properties": {
          "id": {
            "type": "integer"
          },
          "nombre": {
            "type": "string"
          },
          "fechaCreacion": {
            "type": "string",
            "format": "date"
          },
          "fechaInicioTarea": {
            "type": "string",
            "format": "date"
          },
          "fechaFinalizacion": {
            "type": "string",
            "format": "date"
          },
          "idEmpleado": {
            "type": "integer"
          },
          "idEstado": {
            "type": "integer"
          },
          "empleadoNombre": {
            "type": "string"
          },
          "estadoNombre": {
            "type": "string"
          }
        }
      },
      "CreateTareaBody": {
        "type": "object",
        "required": [
          "nombre",
          "fechaCreacion",
          "fechaInicioTarea",
          "fechaFinalizacion",
          "idEmpleado"
        ],
        "additionalProperties": false,
        "properties": {
          "nombre": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200
          },
          "fechaCreacion": {
            "type": "string",
            "format": "date"
          },
          "fechaInicioTarea": {
            "type": "string",
            "format": "date"
          },
          "fechaFinalizacion": {
            "type": "string",
            "format": "date"
          },
          "idEmpleado": {
            "type": "integer",
            "minimum": 1
          },
          "estadoNombre": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100
          }
        }
      },
      "UpdateTareaBody": {
        "type": "object",
        "required": [
          "nombre",
          "fechaCreacion",
          "fechaInicioTarea",
          "fechaFinalizacion",
          "idEmpleado"
        ],
        "additionalProperties": false,
        "properties": {
          "nombre": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200
          },
          "fechaCreacion": {
            "type": "string",
            "format": "date"
          },
          "fechaInicioTarea": {
            "type": "string",
            "format": "date"
          },
          "fechaFinalizacion": {
            "type": "string",
            "format": "date"
          },
          "idEmpleado": {
            "type": "integer",
            "minimum": 1
          }
        }
      },
      "CambiarEstadoBody": {
        "type": "object",
        "required": [
          "idEstado"
        ],
        "additionalProperties": false,
        "properties": {
          "idEstado": {
            "type": "integer",
            "minimum": 1
          }
        }
      },
      "TareaIdParams": {
        "type": "object",
        "required": [
          "id"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "minimum": 1
          }
        }
      },
      "CategoriaParams": {
        "type": "object",
        "required": [
          "categoria"
        ],
        "properties": {
          "categoria": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100
          }
        }
      }
    }
  },
  "paths": {
    "/health": {
      "get": {
        "operationId": "livenessCheck",
        "summary": "Liveness probe",
        "tags": [
          "Health"
        ],
        "description": "Always returns 200. Does not touch the database.",
        "responses": {
          "200": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/health/ready": {
      "get": {
        "operationId": "readinessCheck",
        "summary": "Readiness probe",
        "tags": [
          "Health"
        ],
        "description": "Returns 200 when the database is reachable, 503 otherwise.",
        "responses": {
          "200": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          },
          "503": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              }
            }
          }
        }
      }
    },
    "/empleados/": {
      "get": {
        "operationId": "listEmpleados",
        "summary": "List all employees",
        "tags": [
          "Empleados"
        ],
        "description": "Returns an array of all employees ordered by id ascending.",
        "responses": {
          "200": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Empleado"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createEmpleado",
        "summary": "Create an employee",
        "tags": [
          "Empleados"
        ],
        "description": "Creates and returns the new employee with status 201.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateEmpleadoBody"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Empleado"
                }
              }
            }
          },
          "400": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              }
            }
          }
        }
      }
    },
    "/empleados/{id}": {
      "get": {
        "operationId": "getEmpleado",
        "summary": "Get an employee by id",
        "tags": [
          "Empleados"
        ],
        "description": "Returns a single employee. 404 if not found.",
        "parameters": [
          {
            "schema": {
              "type": "integer",
              "minimum": 1
            },
            "in": "path",
            "name": "id",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Empleado"
                }
              }
            }
          },
          "404": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "updateEmpleado",
        "summary": "Update an employee",
        "tags": [
          "Empleados"
        ],
        "description": "Replaces all mutable fields of an employee. 404 if not found.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateEmpleadoBody"
              }
            }
          }
        },
        "parameters": [
          {
            "schema": {
              "type": "integer",
              "minimum": 1
            },
            "in": "path",
            "name": "id",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Empleado"
                }
              }
            }
          },
          "400": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              }
            }
          },
          "404": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteEmpleado",
        "summary": "Delete an employee",
        "tags": [
          "Empleados"
        ],
        "description": "Deletes the employee. 204 on success, 404 if not found, 422 if the employee owns tasks (FK restrict).",
        "parameters": [
          {
            "schema": {
              "type": "integer",
              "minimum": 1
            },
            "in": "path",
            "name": "id",
            "required": true
          }
        ],
        "responses": {
          "204": {
            "description": "Default Response"
          },
          "404": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              }
            }
          },
          "422": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              }
            }
          }
        }
      }
    },
    "/empleados/{id}/tareas": {
      "get": {
        "operationId": "listTareasForEmpleado",
        "summary": "List tasks for an employee",
        "tags": [
          "Empleados"
        ],
        "description": "Returns all tasks assigned to the employee. Empty array if none. 404 if the employee does not exist.",
        "parameters": [
          {
            "schema": {
              "type": "integer",
              "minimum": 1
            },
            "in": "path",
            "name": "id",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Tarea"
                  }
                }
              }
            }
          },
          "404": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              }
            }
          }
        }
      }
    },
    "/estados/": {
      "get": {
        "operationId": "listEstados",
        "summary": "List all statuses",
        "tags": [
          "Estados"
        ],
        "description": "Returns all status catalogue entries ordered by id ascending.",
        "responses": {
          "200": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Estado"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createEstado",
        "summary": "Create a status",
        "tags": [
          "Estados"
        ],
        "description": "Creates a new status entry. 409 if the name already exists.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateEstadoBody"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Default Response",

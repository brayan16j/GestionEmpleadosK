generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Empleado {
  id           Int      @id @default(autoincrement())
  nombre       String
  fechaIngreso DateTime @map("fecha_ingreso") @db.Date
  salario      Decimal  @db.Decimal(12, 2)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tareas Tarea[]

  @@map("empleado")
}

model Estado {
  id                Int     @id @default(autoincrement())
  nombre            String  @unique
  categoria         String
  cambiosPermitidos String? @map("cambios_permitidos")

  tareas Tarea[]

  @@map("estado")
}

model Tarea {
  id                Int      @id @default(autoincrement())
  nombre            String
  fechaCreacion     DateTime @map("fecha_creacion") @db.Date
  fechaInicioTarea  DateTime @map("fecha_inicio_tarea") @db.Date
  fechaFinalizacion DateTime @map("fecha_finalizacion") @db.Date
  idEmpleado        Int      @map("id_empleado")
  idEstado          Int      @map("id_estado")

  empleado Empleado @relation(fields: [idEmpleado], references: [id], onDelete: Restrict, onUpdate: Cascade)
  estado   Estado   @relation(fields: [idEstado], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@map("tareas")
}

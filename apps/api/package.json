{
  "name": "@employeek/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist .turbo .tsbuildinfo",
    "db:generate": "prisma generate",
    "postinstall": "prisma generate"
  },
  "devDependencies": {
    "@employeek/eslint-config": "workspace:*",
    "@employeek/tsconfig": "workspace:*",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.1",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.8.0",
    "tsx": "^4.21.0",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/env": "^6.0.0",
    "@fastify/sensible": "^6.0.4",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "fastify": "^5.8.5",
    "zod": "^4.3.6"
  }
}

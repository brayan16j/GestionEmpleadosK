# EmployeeK — local environment template
#
# Copy to `.env` at the repo root:  cp .env.example .env
# `.env` is gitignored; never commit real credentials.

# Postgres superuser for the local container (created on first boot).
POSTGRES_USER=employeek

# Local-only password. Rotate freely — this DB is ephemeral per-developer.
POSTGRES_PASSWORD=employeek_local_dev

# Database created on first boot.
POSTGRES_DB=employeek

# Host port exposed by the container. Override if 5432 is taken on your host.
POSTGRES_PORT=5432

# Full connection string consumed by the app (Prisma in CH3, Fastify in CH4).
# Keep user/password/port/db aligned with the values above.
DATABASE_URL=postgresql://employeek:employeek_local_dev@localhost:5432/employeek?schema=public

# Fastify API binding (CH4). Override if 4000 is taken.
PORT=4000

# Bind host. 0.0.0.0 listens on all interfaces; 127.0.0.1 restricts to localhost.
HOST=0.0.0.0

# Comma-separated list of allowed browser origins (CORS).
# Default covers Vite's dev port (CH5); add prod origins as they appear.
CORS_ORIGINS=http://localhost:5173

# Pino log level. Use `debug` in dev for verbose output, `info`/`warn` in prod.
LOG_LEVEL=info

# Vite web app — base URL of the Fastify API (CH5).
VITE_API_URL=http://localhost:4000

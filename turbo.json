{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "tasks": {
    "build": {
      "dependsOn": ["^build", "db:generate"],
      "outputs": ["dist/**", "!.turbo/**"]
    },
    "lint": {
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build", "db:generate"],
      "outputs": ["*.tsbuildinfo", ".tsbuildinfo"]
    },
    "test": {
      "dependsOn": ["^build", "db:generate"],
      "outputs": ["coverage/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "preview": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    },
    "db:generate": {
      "cache": true,
      "inputs": ["prisma/schema.prisma"],
      "outputs": [
        "node_modules/.prisma/**",
        "node_modules/@prisma/client/**",
        "../../node_modules/.pnpm/@prisma+client*/node_modules/.prisma/**",
        "../../node_modules/.pnpm/@prisma+client*/node_modules/@prisma/client/**"
      ]
    },
    "@employeek/api#openapi:dump": {
      "cache": true,
      "inputs": ["src/**", "package.json", "tsconfig.json"],
      "outputs": ["../../packages/api-types/openapi.json"]
    },
    "@employeek/api-types#build": {
      "dependsOn": ["@employeek/api#openapi:dump"],
      "inputs": ["openapi.json", "src/**", "tsconfig.json", "package.json"],
      "outputs": ["dist/**", "src/generated.ts"]
    }
  }
}
